# secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this structure into the Streamlit Cloud "Secrets" editor.
# Do NOT commit your real secrets to GitHub.
#
# HOW TO GET THESE VALUES:
#   1. Go to console.cloud.google.com → IAM & Admin → Service Accounts
#   2. Create a service account → Add Key → JSON
#   3. Open the JSON file. Copy the fields below from it.
#   4. Share your Google Sheet AND Drive folder with the client_email (Editor).
# ─────────────────────────────────────────────────────────────────────────────

[google_credentials]
type = "service_account"
project_id = "your-project-id"
private_key_id = "abc123..."
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
client_email = "your-service-account@your-project.iam.gserviceaccount.com"
client_id = "123456789"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"

[settings]
# The long ID at the end of your Drive folder URL:
# https://drive.google.com/drive/folders/THIS_PART_HERE
drive_folder_id = "1aBcDeFgHiJkLmNoPqRsTuVwXyZ"
teacher_email = "dummy@gmail.com"

# The full URL of your Google Sheet (the one with 1 data row)
sheet_url = "https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit"

# Password the instructor uses to access ?role=admin
admin_password = "ProfessorChoice2026"
